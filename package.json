{
  "name": "jetpac-sysml-v2",
  "version": "0.1.0",
  "description": "A retro Jetpac-inspired game that teaches SysML v2 notation",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "server": "npx tsx server/bridge.ts",
    "start": "node esbuild.config.mjs --watch & npx tsx server/bridge.ts",
    "build": "node esbuild.config.mjs",
    "build:server": "npx esbuild server/bridge.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs --external:sysml-v2-lsp",
    "serve": "node dist/server.mjs",
    "test": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@microsoft/applicationinsights-web": "^3.3.11",
    "sysml-v2-lsp": "^0.6.0"
  }
}
